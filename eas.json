{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "homolog": {
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "homolog",
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false,
        "distribution": "store"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "homolog": {
      "ios": {
        "appleTeamId": "N24BLRHS7C",
        "ascAppId": "6776004704"
      },
      "android": {
        "track": "internal"
      }
    },
    "production": {}
  }
}
