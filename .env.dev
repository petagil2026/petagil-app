# ===========================================
# PetÁgil App — Environment Variables (DEV)
# ===========================================
# Arquivo: .env.dev
# Descrição: Valores de referência do ambiente DEV. Versionado no repo.
# Para usar localmente: `cp .env.dev .env` (o .env é gitignored).
# Nesta fase de fundação o app é frontend-only com mocks.
# ===========================================

# API Configuration
# Base URL do backend — placeholder p/ mocks locais
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Web Auth (IdP) URL — vazio nesta fase (auth mockado)
EXPO_PUBLIC_WEB_AUTH_URL=

# Sentry DSN — vazio desabilita o Sentry
EXPO_PUBLIC_SENTRY_DSN=

# Web app URL — placeholder (sem painel web nesta fase)
EXPO_PUBLIC_WEB_URL=
