{
  "expo": {
    "name": "PetÁgil",
    "slug": "petagil",
    "scheme": "petagil",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.verzel.petagil",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.verzel.petagil",
      "usesCleartextTraffic": true,
      "versionCode": 1
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#19212b"
          }
        }
      ],
      [
        "./plugins/withTransparentSplashLogo.cjs",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      "expo-localization",
      [
        "@sentry/react-native/expo",
        {
          "organization": "petagil",
          "project": "petagil-app"
        }
      ]
    ]
  }
}
