# ===========================================
# PetÁgil App — Environment Variables Template
# ===========================================
# Arquivo: .env.example
# Descrição: Template para configuração de variáveis de ambiente.
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
#    cp .env.example .env
# 2. Substitua os valores placeholder pelos valores do seu ambiente
# 3. NUNCA commite o arquivo .env no repositório!
# ===========================================

# API Configuration
# Base URL do backend (Django/mocks). Nesta fase use um placeholder local.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Web Auth (IdP) URL — servidor OAuth para token exchange (vazio = auth mockado)
EXPO_PUBLIC_WEB_AUTH_URL=

# Sentry DSN — deixe vazio para desabilitar o Sentry
EXPO_PUBLIC_SENTRY_DSN=

# Web app URL — base do frontend web (links de compartilhamento). Sem trailing slash.
# Vazio nesta fase (sem painel web).
EXPO_PUBLIC_WEB_URL=
