{
  "name": "petagil",
  "version": "1.0.0",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "npm run i18n && expo run:android",
    "ios": "npm run i18n && expo run:ios",
    "dev": "expo start --dev-client",
    "apk:docker": "docker compose run --rm android-build",
    "apk:install": "adb install -r build-output/app-debug.apk",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint && npm run format:check",
    "i18n:extract": "lingui extract --clean",
    "i18n:compile": "lingui compile",
    "i18n:check": "node scripts/check-i18n-complete.mjs",
    "i18n": "lingui extract --clean && lingui compile",
    "eas-build-post-install": "npm run i18n",
    "prepare": "git config core.hooksPath scripts/hooks || true"
  },
  "dependencies": {
    "@expo-google-fonts/baloo-2": "^0.4.2",
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo-google-fonts/rubik": "^0.4.2",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@lingui/core": "^5.9.3",
    "@lingui/react": "^5.9.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.9.1",
    "@react-navigation/native": "^7.1.27",
    "@react-navigation/native-stack": "^7.9.1",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/react-query": "^5.90.20",
    "expo": "~54.0.30",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "^14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-localization": "~17.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "^1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "^0.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@lingui/babel-plugin-lingui-macro": "^5.9.3",
    "@lingui/cli": "^5.9.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lingui": "^0.13.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.16",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.53.0"
  },
  "private": true
}
